  "source_type": {
    "description": "内容来源类型",
    "values": ["official", "github-issue", "github-pr", "blog", "paper", "community"],
    "labels": {
      "official": "官方文档",
      "github-issue": "GitHub Issue",
      "github-pr": "GitHub PR",
      "blog": "官方博客",
      "paper": "学术论文",
      "community": "社区讨论"
    }
  },

  "source_org": {
    "description": "来源组织",
    "values": ["amd", "rocm", "pytorch", "tensorflow", "paddle", "llvm", "mesa", "linux"],
    "labels": {
      "amd": "AMD",
      "rocm": "ROCm",
      "pytorch": "PyTorch",
      "tensorflow": "TensorFlow",
      "paddle": "PaddlePaddle",
      "llvm": "LLVM",
      "mesa": "Mesa",
      "linux": "Linux Kernel"
    }
  },

  "credibility": {
    "description": "可信度评级（1-5★）",
    "values": [1, 2, 3, 4, 5],
    "labels": {
      "5": "★★★★★ 官方权威",
