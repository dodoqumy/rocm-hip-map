    "values": ["ubuntu-20.04", "ubuntu-22.04", "ubuntu-24.04", "rhel", "arch", "wsl2", "docker", "kubernetes", "linux", "windows"],
    "labels": {
      "ubuntu-20.04": "Ubuntu 20.04",
